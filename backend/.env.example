# ── Gmail SMTP credentials ──────────────────────────────────────────────
# GMAIL_APP_PASSWORD is NOT your normal Gmail password. Generate one here:
#   1. Turn ON 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password:      https://myaccount.google.com/apppasswords
#   3. Copy the 16-character password (spaces don't matter) below.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ── OpenAI (optional) ───────────────────────────────────────────────────
# If set, emails are written by AI (tailored per company). If unset or the
# API fails, the app automatically falls back to the built-in template.
# Get a key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
#   Good cheap picks: gpt-4.1-mini (best quality/price here) or gpt-4o-mini (cheapest).
#   NOTE: gpt-5 / o-series models reject a custom temperature — they need code
#   changes to work with this app. Stick to gpt-4.1-mini / gpt-4o-mini / gpt-4o.

# ── Digest (optional) ───────────────────────────────────────────────────
# If set, the "Email digest" button sends a summary of your sends here.
# DIGEST_TO=you@gmail.com

# ── LinkedIn → email lookup via Apify (optional) ────────────────────────
# If set, the app shows a "Find email from LinkedIn" box that looks up a
# person's email from their profile URL and auto-fills the compose form.
# Get a token: Apify Console → Settings → Integrations → API token.
# Note: each lookup costs Apify credits (the default actor is ~$20 / 1000
# verified emails). Results are best-effort — always sanity-check the email.
# APIFY_TOKEN=apify_api_...
#
# Optional: swap the actor or remap output fields without code changes.
# Default actor: https://apify.com/iron-crawler/linkedin-email-finder-profile
# APIFY_ACTOR_ID=iron-crawler/linkedin-email-finder-profile
# APIFY_EMAIL_FIELD=email
# APIFY_NAME_FIELD=full_name
# APIFY_COMPANY_FIELD=current_company_name
#
# Coverage is hit-or-miss per actor, so if the primary finds no email the app
# automatically retries a second actor before giving up. Swap it (or clear it to
# disable the fallback):
# APIFY_FALLBACK_ACTOR_ID=vulnv/linkedin-email-finder

# ── LinkedIn job search (uses the same APIFY_TOKEN above) ────────────────
# When APIFY_TOKEN is set, the app also shows a "Job Search" section that
# finds fresher (0-1 yr) software jobs in India, AI-checks each for
# eligibility, and tracks the ones you apply to. Each search is one Apify
# run plus a cheap OpenAI call per job.
# Optional: swap the job-search actor (default: fantastic-jobs advanced-linkedin-job-search-api).
# APIFY_JOBS_ACTOR_ID=vIGxjRrHqDTPuE6M4

# ── Optional overrides (defaults shown) ─────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# PORT=8080
# ALLOWED_ORIGIN=http://localhost:3000
# DATA_DIR=data
