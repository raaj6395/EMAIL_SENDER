# ── Gmail SMTP credentials ──────────────────────────────────────────────
# GMAIL_APP_PASSWORD is NOT your normal Gmail password. Generate one here:
#   1. Turn ON 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password:      https://myaccount.google.com/apppasswords
#   3. Copy the 16-character password (spaces don't matter) below.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ── OpenAI (optional) ───────────────────────────────────────────────────
# If set, emails are written by AI (tailored per company). If unset or the
# API fails, the app automatically falls back to the built-in template.
# Get a key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Digest (optional) ───────────────────────────────────────────────────
# If set, the "Email digest" button sends a summary of your sends here.
# DIGEST_TO=you@gmail.com

# ── Optional overrides (defaults shown) ─────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# PORT=8080
# ALLOWED_ORIGIN=http://localhost:3000
# DATA_DIR=data
